<?xml version="1.0" encoding="utf-8"?><PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:app="http://schemas.android.com/apk/res-auto"    android:name="Notification">    <PreferenceCategory android:layout="@layout/mezo_settings_top" />    <PreferenceCategory        android:textColor="@color/accessibility_footer_color"        android:title="@string/mezo_notif_anim_1"        app:layout="@layout/mezo_unique_divider" />    <MyXDropDownPreference        android:title="@string/noti_icon_size"        android:key="mezo_notif_icons_size"        android:defaultValue="35"        app:entries="@array/mezo_notif_icons_entries"        app:entryValues="@array/mezo_notif_icons_values"        intent="my.intent.action.REFRESH_STATUSBAR" />    <XdCheckBoxPreference        android:title="Hide persistent DND notification"        android:key="bg_hide_lock_dnd"        android:summary="Hide Dnd button from statusbar"        android:defaultValue="true" />    <XMiuiCheckBoxPreference        android:title="@string/icon_mezo_app_color_title"        android:key="icon_mezo_app_color"        android:summary="Color Notification Icons On Status Bar"        android:defaultValue="true"        intent="my.intent.action.REFRESH_STATUSBAR" />    <XMiuiCheckBoxPreference        android:title="@string/expand_top_notification"        android:key="status_bar_expand_top_notification" />    <XMiuiCheckBoxPreference        android:title="@string/notif_sound_title"        android:key="notif_mezo_sound"        android:defaultValue="true" />    <XdOverlayCheckBox        android:title="@string/mezo_notif_transp"        android:key="mezo_notification"        android:summary="@string/mezo_notif_transp_summ"        android:defaultValue="false" />    <XMiuiCheckBoxPreference        android:title="@string/show_notif_on_lock_mezo_titt"        android:key="show_notif_mezo_lock"        android:summary="@string/show_notif_on_lock_mezo_summ"        android:defaultValue="true" />    <XMiuiCheckBoxPreference        android:title="Smart notifications"        android:key="smart_notifications"        android:summary="Allow all notifications to show in the Toast Notification"        android:defaultValue="false" />    <XdCheckBoxPreference        android:title="@string/disable_heads_up"        android:key="disable_headsup"        android:summary="Restrict notification to heads up"        android:defaultValue="false" />    <XMiuiCheckBoxPreference        android:title="@string/privacy_mezo_dot_title"        android:key="privacy_mezo_dot"        android:summary="@string/privacy_mezo_dot_summ"        android:defaultValue="true"        intent="my.intent.action.REFRESH_STATUSBAR" />    <XMiuiCheckBoxPreference        android:title="@string/mock_locations_title"        android:key="enable_mezo_mock_locations"        android:summary="@string/mock_locations_title_summ"        android:defaultValue="false" />    <XMiuiCheckBoxPreference        android:title="@string/launcher_mezo_9"        android:key="lock_to_app_enabled"        android:defaultValue="false" />    <XMiuiCheckBoxPreference        android:title="@string/sizzling_title"        android:key="vibrate_mezo_on"        android:defaultValue="false"        android:summaryOn="@string/check_on1"        android:summaryOff="@string/check_off1" />    <XMiuiCheckBoxPreference        android:title="Network Dealy"        android:key="network_dealy"        android:summary="Decrease Network Dealy 4s to 1s"        android:defaultValue="false" />    <XMiuiCheckBoxPreference        android:title="@string/edge_mode_enabled_title"        android:key="edge_mode_enabled"        android:defaultValue="false" />    <PreferenceCategory        android:persistent="false"        android:title="Other Notifications"        android:key="notifications"        app:layout="@layout/mezo_unique_divider" />    <Preference        android:title="Quick Replies"        android:summary="Enable quick replies for some app in the notification (e.g Whatsapp, WeChat, QQ)">        <intent            android:targetPackage="com.miui.securitycenter"            android:targetClass="com.miui.gamebooster.ui.QuickReplySettingsActivity" />    </Preference>    <com.android.settingslib.miuisettings.preference.Preference        android:title="Notification history"        android:summary="Show recent and snoozed notifications">        <intent            android:targetPackage="com.android.settings"            android:targetClass="com.android.settings.notification.history.NotificationHistoryActivity" />    </com.android.settingslib.miuisettings.preference.Preference>    <com.android.settingslib.miuisettings.preference.Preference        android:persistent="false"        android:title="Beam for notifications"        android:key="flash_notifications_preference"        android:summary="Visualizes notification sound using camera flash &amp; screen"        android:fragment="com.android.settings.accessibility.FlashNotificationsPreferenceFragment"        app:controller="com.android.settings.accessibility.FlashNotificationsPreferenceController"        default="false" />    <PreferenceCategory        android:textColor="@color/accessibility_footer_color"        android:title="@string/mezo_notif_anim_19"        app:layout="@layout/mezo_unique_divider" />    <XMiuiCheckBoxPreference        android:title="@string/mezo_notif_anim_2"        android:key="anim_expand_enable"        android:defaultValue="false"        intent="com.android.settings.NotifColorSett" />    <XMiuiListPreference        android:entries="@array/anim_expand_name"        android:title="@string/mezo_notif_anim_3"        android:key="anim_expand_style"        android:summary="%s"        android:dependency="anim_expand_enable"        android:defaultValue="5"        android:entryValues="@array/anim_expand_style"        intent="com.android.settings.NotifColorSett" />    <XMiuiDropDownPreference        android:title="@string/mezo_notif_anim_21"        android:key="loopanim"        android:dependency="anim_expand_enable"        android:defaultValue="3"        app:entries="@array/loopanim_name"        app:entryValues="@array/loopanim_values" />    <XMiuiListPreference        android:entries="@array/notif_interpolator_entries"        android:title="@string/mezo_notif_anim_4"        android:key="anim_expand_interpolator"        android:summary="%s"        android:dependency="anim_expand_enable"        android:defaultValue="5"        android:entryValues="@array/notif_interpolator_values"        intent="com.android.settings.NotifColorSett" />    <EdSeekBarPreference        android:title="@string/mezo_notif_anim_5"        android:key="anim_expand_duration"        android:dependency="anim_expand_enable"        android:defaultValue="1000"        intent="my.settings.intent.notif_expanded_header.CHANGE"        max="2000"        min="600" />    <PreferenceCategory        android:textColor="@color/accessibility_footer_color"        android:title="@string/mezo_notif_anim_20"        app:layout="@layout/mezo_unique_divider" />    <XMiuiCheckBoxPreference        android:title="@string/mezo_notif_anim_2"        android:key="anim_expand_enable2"        android:defaultValue="false"        intent="com.android.settings.NotifColorSett" />    <XMiuiListPreference        android:entries="@array/anim_expand_name2"        android:title="@string/mezo_notif_anim_3"        android:key="anim_expand_style2"        android:summary="%s"        android:dependency="anim_expand_enable2"        android:defaultValue="4"        android:entryValues="@array/anim_expand_style2"        intent="com.android.settings.NotifColorSett" />    <XMiuiDropDownPreference        android:title="@string/mezo_notif_anim_21"        android:key="loopanim2"        android:dependency="anim_expand_enable2"        android:defaultValue="3"        app:entries="@array/loopanim_name2"        app:entryValues="@array/loopanim_values2" />    <XMiuiListPreference        android:entries="@array/notif_interpolator_entries"        android:title="@string/mezo_notif_anim_4"        android:key="anim_expand_interpolator2"        android:summary="%s"        android:dependency="anim_expand_enable2"        android:defaultValue="5"        android:entryValues="@array/notif_interpolator_values"        intent="com.android.settings.NotifColorSett" />    <EdSeekBarPreference        android:title="@string/mezo_notif_anim_5"        android:key="anim_expand_duration2"        android:dependency="anim_expand_enable2"        android:defaultValue="1000"        intent="my.settings.intent.notif_expanded_header.CHANGE"        max="2000"        min="600" /></PreferenceScreen>