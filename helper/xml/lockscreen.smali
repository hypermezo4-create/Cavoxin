    <XMiuiCheckBoxPreference        android:title="@string/show_notif_on_lock_mezo_titt"        android:key="show_notif_mezo_lock"        android:summary="@string/show_notif_on_lock_mezo_summ"        android:defaultValue="true" />    <XMiuiCheckBoxPreference        android:title="@string/sizzling_title"        android:key="vibrate_mezo_on"        android:defaultValue="false"        android:summaryOn="@string/check_on1"        android:summaryOff="@string/check_off1" />    <XMiuiListPreference        android:entries="@array/charge_animation_style_entries"        android:title="@string/charge_animation_style_title"        android:key="charge_animation_type"        android:summary="%s"        android:defaultValue="1"        android:entryValues="@array/charge_animation_style_values" />    <PreferenceCategory        android:layout="@layout/mezo_unique_divider"        android:title="@string/lock_mezo_battery_0">        <XMiuiCheckBoxPreference            android:title="@string/lock_mezo_battery_1"            android:key="bg_extra_charging_info"            android:summary="@string/lock_mezo_battery_2"            android:defaultValue="true" />        <XMiuiCheckBoxPreference            android:title="@string/lock_mezo_battery_3"            android:key="bg_show_temp"            android:summary="@string/lock_mezo_battery_4"            android:dependency="bg_extra_charging_info"            android:defaultValue="true" />        <XMiuiCheckBoxPreference            android:title="@string/lock_mezo_battery_5"            android:key="bg_hide_original_charging_text"            android:summary="@string/lock_mezo_battery_6"            android:dependency="bg_extra_charging_info"            android:defaultValue="true" />        <XMiuiCheckBoxPreference            android:title="@string/lock_mezo_battery_7"            android:key="bg_show_ampere"            android:summary="@string/lock_mezo_battery_8"            android:dependency="bg_extra_charging_info"            android:defaultValue="true" />        <XMiuiCheckBoxPreference            android:title="@string/lock_mezo_battery_9"            android:key="bg_show_voltage"            android:summary="@string/lock_mezo_battery_10"            android:dependency="bg_extra_charging_info"            android:defaultValue="false" />        <XMiuiCheckBoxPreference            android:title="@string/lock_mezo_battery_11"            android:key="bg_show_power"            android:summary="@string/lock_mezo_battery_12"            android:dependency="bg_extra_charging_info"            android:defaultValue="true" />        <XMiuiListPreference            android:entries="@array/bg_interval_entries"            android:title="@string/lock_mezo_battery_13"            android:key="bg_refresh_interval"            android:summary="@string/lock_mezo_battery_14"            android:dependency="bg_extra_charging_info"            android:defaultValue="2000"            android:entryValues="@array/bg_interval_values" />        <EdSeekBarPreference            android:title="@string/lock_mezo_battery_15"            android:key="bg_charging_info_text_size"            android:dependency="bg_extra_charging_info"            android:defaultValue="15"            max="30"            min="0" />    </PreferenceCategory>