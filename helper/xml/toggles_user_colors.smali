<?xml version="1.0" encoding="utf-8"?><PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:app="http://schemas.android.com/apk/res/com.android.settings"    android:name="System">    <PreferenceCategory        android:layout="@layout/mezo_settings_top"        android:title="@string/qs_toggles_customizations_title_summary" />    <PreferenceCategory        android:title="@string/restart_sisui_tit_2"        app:layout="@layout/mezo_unique_divider" />    <MyXCheckBoxPreference        android:icon="@drawable/ic_modifier_keys_reset"        android:title="@string/restart_sisui_tit_2"        android:summary="@string/restart_sisui_tit_summ_2"        intent="my.intent.action.REFRESH_SYSTEMUI" />    <PreferenceCategory        android:title="@string/old_toggles_cust_title2"        app:layout="@layout/mezo_unique_divider" />    <EdSeekBarPreference        android:title="@string/toggle_count_title"        android:key="toggles_mezo_count_single"        android:defaultValue="6"        intent="my.intent.action.REFRESH_STATUSBAR"        max="7"        min="3" />    <EdSeekBarPreference        android:title="@string/toggles_count_title"        android:key="toggles_mezo_count_expanded"        android:defaultValue="6"        intent="my.intent.action.REFRESH_STATUSBAR"        max="7"        min="3" />    <EdSeekBarPreference        android:title="@string/toggles_count_rows_title"        android:key="toggles_mezo_count_expanded_rows"        android:defaultValue="3"        intent="my.intent.action.REFRESH_STATUSBAR"        max="5"        min="2" />    <PreferenceCategory        android:title="@string/old_toggles_cust_title"        app:layout="@layout/mezo_unique_divider">        <XMiuiCheckBoxPreference            android:title="@string/old_qs_toggles_customizations_title"            android:key="QS_bg_color_show"            android:defaultValue="false"            android:summaryOn="@string/new_notif_user_colors_use"            android:summaryOff="@string/new_notif_user_colors_default"            intent="my.intent.action.REFRESH_STATUSBAR" />        <XMiuiColorPickerPreference            android:title="@string/QS_bg_color_enabled_title"            android:key="QS_bg_color_enabled"            android:defaultValue="#ff00ff00"            alphaSlider="true"            hexValue="true"            intent="my.intent.action.REFRESH_STATUSBAR" />        <XMiuiColorPickerPreference            android:title="@string/QS_bg_color_disabled_title"            android:key="QS_bg_color_disabled"            android:defaultValue="#1a000000"            alphaSlider="true"            hexValue="true"            intent="my.intent.action.REFRESH_STATUSBAR" />        <XMiuiColorPickerPreference            android:title="@string/QS_bg_color_title"            android:key="QS_bg_color"            android:defaultValue="#00000000"            alphaSlider="true"            hexValue="true"            intent="my.intent.action.REFRESH_STATUSBAR" />        <XMiuiCheckBoxPreference            android:title="@string/new_notif_background_color_force_title"            android:key="new_QS_background_color_force"            android:defaultValue="false"            arrowX="45"            arrowY="2"            intent="my.intent.action.REFRESH_STATUSBAR"            margin="1" />        <EdSeekBarPreference            android:title="@string/new_notif_background_alpha_title"            android:key="new_QS_background_alpha"            android:dependency="new_QS_background_color_force"            android:defaultValue="0"            intent="my.intent.action.REFRESH_STATUSBAR"            margin="2"            max="255"            min="-255"            step="15" />        <XMiuiColorPickerPreference            android:title="@string/QS_fg_color_enabled_title"            android:key="QS_fg_color_enabled"            android:defaultValue="#ffffffff"            alphaSlider="true"            hexValue="true"            intent="my.intent.action.REFRESH_STATUSBAR" />        <XMiuiColorPickerPreference            android:title="@string/QS_fg_color_disabled_title"            android:key="QS_fg_color_disabled"            android:defaultValue="#ffffffff"            alphaSlider="true"            hexValue="true"            intent="my.intent.action.REFRESH_STATUSBAR" /></PreferenceScreen>