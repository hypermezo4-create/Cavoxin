<?xml version="1.0" encoding="utf-8"?><PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"    xmlns:app="http://schemas.android.com/apk/res/com.android.settings"    android:name="About Phone">    <PreferenceCategory android:layout="@layout/mezo_settings_top" />    <PreferenceCategory        android:textColor="@color/accessibility_footer_color"        android:title="@string/mezo_about_phone_title"        app:layout="@layout/mezo_pref_layout">        <XMiuiCheckBoxPreference            android:title="Change Device Name"            android:key="device_name"            android:summary="Change Device Name In About Page"            android:defaultValue="false" />        <MyEditTextPreference            android:title="Device Name"            android:key="device_name_card"            android:dependency="device_name"            android:defaultValue="Redmi Note 13 Pro 5G+" />        <MyEditTextPreference            android:title="Verison Name In About Phone Page"            android:key="mezo_version_name"            android:defaultValue="3.0.6.0" />        <XMiuiCheckBoxPreference            android:title="Enable Xiaomi.EU Specs"            android:key="horizontal_specs"            android:summary="Enable Xiaomi.eu like Specs"            android:defaultValue="false" />        <XMiuiCheckBoxPreference            android:title="Gradient Blur Logo"            android:key="gradient_blur_logo"            android:defaultValue="false" />        <XMiuiDropDownPreference            android:title="@string/mod_about_phone_title"            android:key="change_mod"            android:summary="%s"            android:defaultValue="0"            app:entries="@array/mezo_about_phone_mod_entries"            app:entryValues="@array/mezo_about_phone_mod_values" />        <XMiuiCheckBoxPreference            android:title="@string/transparent_blur_background_title"            android:key="lock_backg"            android:dependency="change_mod"            android:defaultValue="false"            android:summaryOn="Transparent"            android:summaryOff="Blur" />        <XMiuiCheckBoxPreference            android:title="@string/Show_wall_lockscreen_title"            android:key="lock_wall_about"            android:dependency="change_mod"            android:defaultValue="false"            android:summaryOn="Wallpaper"            android:summaryOff="Lockscreen" />        <XMiuiCheckBoxPreference            android:title="@string/mezo_show_weather_title"            android:key="show_weather_header"            android:dependency="lock_backg"            android:defaultValue="false"            android:summaryOn="On"            android:summaryOff="Off" />        <XMiuiCheckBoxPreference            android:title="@string/change_mini_logo_title"            android:key="hide_mini"            android:dependency="change_mod"            android:defaultValue="false"            android:summaryOn="Mini"            android:summaryOff="Logo" />        <EdSeekBarPreference            android:max="100"            android:title="@string/blur_header_image_title"            android:key="mmu_habout_blur"            android:dependency="change_mod"            android:defaultValue="69"            app:min="0"            enableSummary="true" />        <EdSeekBarPreference            android:max="100"            android:title="@string/blur_mini_wallpaper"            android:key="mmu_wabout_blur"            android:dependency="change_mod"            android:defaultValue="69"            app:min="0"            enableSummary="true" />        <XMiuiCheckBoxPreference            android:title="@string/blur_about_info_background"            android:key="lock_infbackg"            android:dependency="change_mod"            android:defaultValue="false"            android:summaryOn="Blur"            android:summaryOff="Transparent" />        <XMiuiCheckBoxPreference            android:title="@string/Show_wall_lockscreen_title"            android:key="lock_wall_infabout"            android:dependency="lock_infbackg"            android:defaultValue="false"            android:summaryOn="Lockscreen"            android:summaryOff="Wallpaper" /></PreferenceScreen>